VOLCENGINE_APP_ID=your_volcengine_app_id
VOLCENGINE_ACCESS_TOKEN=your_volcengine_access_token
VOLCENGINE_RESOURCE_ID=volc.seedasr.sauc.duration
VOLCENGINE_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# Optional generic ASR fallback for the local backend.
# The extension popup can also save these values locally in Chrome.
# ASR_PROVIDER=volcengine
# Supported values: volcengine, aliyun, tencent, baidu, iflytek
# ASR_APP_ID=your_asr_app_id
# ASR_ACCESS_TOKEN=your_asr_access_token
# ASR_API_KEY=your_asr_api_key_or_dashscope_api_key
# ASR_API_SECRET=your_asr_api_secret
# ASR_SECRET_ID=your_tencent_secret_id
# ASR_SECRET_KEY=your_tencent_secret_key
# ASR_APP_KEY=your_legacy_aliyun_nls_or_baidu_app_key
# ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
# ASR_MODEL=doubao-seed-asr
#
# Aliyun recommended setup:
# ASR_PROVIDER=aliyun
# ASR_API_KEY=your_dashscope_api_key
# ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# ASR_MODEL=qwen3-asr-flash-realtime

# Long-stream stability. Defaults are suitable for livestreams and long videos.
# VOLCENGINE_ASR_ROTATE_MS=270000
# ASR_KEEPALIVE_MS=1000
# ASR_KEEPALIVE_IDLE_MS=1500
# ASR_AUDIO_BUFFER_MAX_MS=8000
# SUBTITLE_PENDING_FRAGMENT_LIMIT=36
# SUBTITLE_PROCESSED_FRAGMENT_LIMIT=50000
# SUBTITLE_TRANSLATION_TIMEOUT_MS=8000

# Translation provider defaults:
# - microsoft: free Microsoft web translation, no API key required
# - ai: OpenAI-compatible or Anthropic-compatible chat API
# - deepseek, mimo, kimi, glm, qwen, minimax, custom: selectable in the popup
# - balanced: AI webpage translation when an API key exists, otherwise Microsoft
# - accurate: context-aware document/PDF AI translation when an API key exists, otherwise Microsoft
TRANSLATION_PROVIDER=microsoft
PAGE_TRANSLATION_PROVIDER=balanced
PDF_TRANSLATION_PROVIDER=accurate

# OpenAI-compatible / Anthropic-compatible translation fallback:
# TRANSLATION_PROVIDER=ai
# AI_TRANSLATION_BASE_URL=https://api.deepseek.com
# AI_TRANSLATION_API_KEY=your_api_key
# AI_TRANSLATION_MODEL=deepseek-v4-flash
# AI_TRANSLATION_DISABLE_THINKING=true
